{
  "name": "evalunia",
  "version": "1.0.0",
  "description": "EVALUNIA",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@lmstudio/sdk": "^1.5.0",
    "bootstrap": "^5.3.5",
    "bootstrap-icons": "^1.11.3",
    "datatables.net": "^2.3.2",
    "datatables.net-bs5": "^2.3.2",
    "jquery": "^3.7.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^39.8.3",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0",
    "standard": "^17.1.2"
  },
  "build": {
    "appId": "com.evalunia.app",
    "productName": "EVALUNIA",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "frontend/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/evalunia_backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}